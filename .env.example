# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@thecapitalguru.net
RESEND_FROM_NAME=The Capital Guru

# App
NEXT_PUBLIC_APP_URL=https://thecapitalguru.net
NEXT_PUBLIC_TELEGRAM_SUPPORT=https://t.me/thecapitalguru_support

# Cron Security
CRON_SECRET=your_random_64_char_string

# Upstash Redis (optional)
UPSTASH_REDIS_REST_URL=your_redis_url
UPSTASH_REDIS_REST_TOKEN=your_redis_token
